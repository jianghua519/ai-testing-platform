AI_PROVIDER=google
AI_GOOGLE_MODEL=gemini-2.5-flash
AI_OPENAI_MODEL=gpt-4.1-mini
AI_OPENAI_BASE_URL=
AI_PROVIDER_TEMPERATURE=0.1
AI_MEMORY_MAX_FACTS=32
AI_ORCHESTRATOR_PORT=8081
AI_ORCHESTRATOR_HOST_PORT=18081
AI_ORCHESTRATOR_BIND_HOST=0.0.0.0
AI_ORCHESTRATOR_STORE_MODE=postgres
AI_ORCHESTRATOR_DATABASE_URL=postgresql://aiwtp:aiwtp-password@postgres:5432/aiwtp
AI_ORCHESTRATOR_RUN_MIGRATIONS=true
AI_ORCHESTRATOR_PLAYWRIGHT_BROWSER=chromium
AI_ORCHESTRATOR_PLAYWRIGHT_HEADLESS=true
AI_ORCHESTRATOR_PLAYWRIGHT_OUTPUT_ROOT=/tmp/aiwtp-ai-orchestrator
AI_ORCHESTRATOR_PLAYWRIGHT_EXECUTABLE_PATH=
AI_ORCHESTRATOR_PLAYWRIGHT_VIDEO_SIZE=1280x720
AI_ORCHESTRATOR_PLAYWRIGHT_SAVE_TRACE=true
AI_ORCHESTRATOR_SCRIPTED_UPLOAD_PATH=/tmp/aiwtp-ai-orchestrator/shared/avatar-smoke.txt
AI_ORCHESTRATOR_EXPLORATION_MAX_STEPS=24
AI_ORCHESTRATOR_EXPLORATION_TIMEOUT_MS=180000
CONTROL_PLANE_BASE_URL=http://127.0.0.1:18080
CONTROL_PLANE_JWT_SECRET=local-control-plane-dev-secret
GOOGLE_API_KEY=
OPENAI_API_KEY=
