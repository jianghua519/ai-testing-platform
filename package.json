{
  "name": "ai-web-testing-platform-v2",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc -b packages/web-dsl-schema packages/dsl-compiler packages/playwright-adapter apps/web-worker apps/control-plane apps/ai-orchestrator",
    "build": "npm run typecheck",
    "compose:postgres:reset": "node ./scripts/reset_compose_postgres.mjs",
    "ai-orchestrator:serve": "node ./scripts/start_ai_orchestrator_server.mjs",
    "ai-orchestrator:migrate:postgres": "node ./scripts/migrate_ai_orchestrator_postgres.mjs",
    "control-plane:serve": "node ./scripts/start_control_plane_server.mjs",
    "control-plane:artifacts:prune": "npm run build && node ./scripts/prune_expired_artifacts.mjs",
    "control-plane:migrate:postgres": "npm run build && node ./scripts/migrate_control_plane_postgres.mjs",
    "playwright:install": "playwright install chromium",
    "sample:saucedemo:checkout": "npm run build && node ./scripts/run_saucedemo_checkout_sample.mjs",
    "sample:saucedemo:checkout:compose": "npm run build && node ./scripts/run_saucedemo_checkout_case_compose.mjs",
    "smoke:ai-orchestrator:mock": "node ./scripts/run_ai_orchestrator_mock_smoke.mjs",
    "smoke:ai-orchestrator:postgres:persistence": "node ./scripts/run_ai_orchestrator_postgres_persistence_smoke.mjs",
    "smoke:ai-orchestrator:workflow": "node ./scripts/run_ai_orchestrator_workflow_smoke.mjs",
    "worker:agent": "node ./scripts/start_polling_web_agent.mjs",
    "smoke:scheduler:compose": "node ./scripts/run_scheduler_compose_smoke.mjs",
    "smoke:web:real": "npm run build && node ./scripts/run_real_browser_smoke.mjs",
    "smoke:control-plane:compose": "node ./scripts/run_control_plane_compose_smoke.mjs",
    "smoke:control-plane:postgres": "npm run build && node ./scripts/run_control_plane_postgres_smoke.mjs",
    "smoke:control-plane:postgres:real": "npm run build && node ./scripts/run_control_plane_postgres_real_smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "dotenv": "^17.2.3",
    "embedded-postgres": "^18.3.0-beta.16",
    "pg-mem": "^3.0.5",
    "playwright": "1.58.2",
    "typescript": "^5.9.2"
  }
}
